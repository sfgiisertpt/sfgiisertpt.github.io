@ARTICLE{2024MNRAS.529.4234B,
       author = {{Bijas}, N. and {Eswaraiah}, Chakali and {Sandhyarani}, Panigrahy and {Jose}, Jessy and {Gopinathan}, Maheswar},
        title = "{A comparative study of dust grain polarization efficiencies in the interstellar and intracluster mediums towards anticentre galaxy}",
      journal = {\mnras},
     keywords = {polarization, dust, extinction, ISM: magnetic fields, Astrophysics - Astrophysics of Galaxies},
         year = 2024,
        month = apr,
       volume = {529},
       number = {4},
        pages = {4234-4247},
     abstract = "{Dust polarization observations at optical wavelengths help understand
        the dust grain properties and trace the plane-of-the-sky
        component of the magnetic field. In this study, we make use of
        published optical polarization data acquired with AIMPOL along
        with distances (d) and extinction (A$_{V}$) data. We study the
        variation of polarization efficiency (P/A$_{V}$) as a function
        of A$_{V}$ in the diffuse interstellar medium (ISM) and
        intracluster mediums (ICM) using the already published
        polarization data of six clusters. Among these clusters, NGC
        2281, NGC 1664, and NGC 1960 are old; while Stock 8, NGC 1931,
        and NGC 1893 are young. We categorize stars towards each cluster
        into foreground, background, and cluster members by employing
        two clustering algorithms GMM and DBSCAN. Thus, classified field
        stars and cluster members are used to reveal the polarization
        properties of ISM and ICM dust, respectively. We find that the
        dust grains located in the diffuse ISM show higher polarization
        efficiencies when compared to those located in the ICM of
        younger clusters.}",
          doi = {10.1093/mnras/stae749},
archivePrefix = {arXiv},
       eprint = {2404.01169},
 primaryClass = {astro-ph.GA},
       adsurl = {https://ui.adsabs.harvard.edu/abs/2024MNRAS.529.4234B},
      adsnote = {Provided by the SAO/NASA Astrophysics Data System}
}

